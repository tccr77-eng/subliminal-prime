# Subliminal Prime — Environment Variables
#
# Copy this file to .env.local for local development and set each value.
# In production, set these in Vercel: Project → Settings → Environment Variables.
# Never commit real values for any of these to git.

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_..., sk_test_...) until you're ready to accept real payments.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret. Create a webhook endpoint at
# https://dashboard.stripe.com/webhooks pointing to /api/stripe-webhook, then
# copy the "Signing secret" (starts with whsec_) here.
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Resend (transactional email) ──────────────────────────────────────────────
# Get from https://resend.com/api-keys (Sending access permission is enough).
RESEND_API_KEY=re_...

# The "From" address shown to customers. The domain must be verified in Resend.
ORDERS_FROM_EMAIL=Subliminal Prime <orders@subliminalprime.com>

# Optional — where replies go (e.g. customer pressing "Reply" in their email client).
ORDERS_REPLY_TO=support@subliminalprime.com
